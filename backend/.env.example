# =============================================
# Firebase Admin SDK (SERVER ONLY)
# Generate: base64 -w 0 service-account.json
# Windows: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
# =============================================
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=

# =============================================
# Firebase Emulator (set true for local dev)
# =============================================
USE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# =============================================
# Gemini benchmark provider + embeddings
# =============================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
BENCHMARK_PRICE_INPUT_PER_1K_USD=0.0003
BENCHMARK_PRICE_OUTPUT_PER_1K_USD=0.0006
BENCHMARK_REQUEST_DELAY_MS=1500
GEMINI_RETRY_MAX_ATTEMPTS=4
GEMINI_RETRY_BASE_DELAY_MS=1500
GEMINI_RETRY_MAX_DELAY_MS=60000

# =============================================
# Supabase knowledge retrieval (optional until seeded)
# =============================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================
# App
# =============================================
NODE_ENV=development
PORT=5001

# =============================================
# Public API (v1) — platform API keys + OpenAPI
# =============================================
# Max requests per minute per API key on /api/v1/* (protected routes)
API_KEY_RATE_LIMIT_PER_MIN=60
# Positive/negative cache TTL for API key Firestore lookups (seconds)
API_KEY_CACHE_TTL_SECONDS=60
# Optional: base URL for OpenAPI "servers" (no trailing slash), e.g.
# https://australia-southeast1-myproject.cloudfunctions.net/api
PUBLIC_API_BASE_URL=
